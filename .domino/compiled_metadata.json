                        {
                            "type": "null"
                        }
                    ],
                    "default": {
                        "agg": {},
                        "groupby": {}
                    },
                    "description": "JSON aggregation rules configuration.",
                    "from_upstream": "never",
                    "title": "aggregation.rules",
                    "widget": "codeeditor-json"
                },
                "net_direction": {
                    "anyOf": [
                        {
                            "additionalProperties": true,
                            "type": "object"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": {},
                    "description": "Configuration for computing network direction based on local network regex.",
                    "from_upstream": "never",
                    "title": "net.direction",
                    "widget": "codeeditor-json"
                }
            },
            "required": [
                "input_file"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "output_file": {
                    "description": "Ouput file path.",
                    "title": "output.file",
                    "type": "string"
                }
            },
            "required": [
                "output_file"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
