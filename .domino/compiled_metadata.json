{
    "SortJSONLByFieldPiece": {
        "name": "SortJSONLByFieldPiece",
        "dependency": {
            "dockerfile": "Dockerfile",
            "requirements_file": null
        },
        "tags": [
            "processing",
            "stream",
            "jsonl"
        ],
        "style": {
            "node_label": "Sort by Field",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa7-solid:arrow-down-1-9",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Sort JSONL records by a specified field (e.g., timestamp).",
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "properties": {
                "input_file": {
                    "description": "Path to the input JSONL file containing messages to process.",
                    "from_upstream": "always",
                    "title": "Input JSONL File",
                    "type": "string"
                },
                "field": {
                    "description": "Name of the field in each JSON message that contains JSON to extract.",
                    "from_upstream": "never",
                    "title": "Field Name",
                    "type": "string"
                },
                "num_workers": {
                    "default": 4,
                    "description": "Number of workers to use.",
                    "from_upstream": "never",
                    "title": "Number of Workers",
                    "type": "integer"
                }
            },
            "required": [
                "input_file",
                "field"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "output_file": {
                    "default": "messages.jsonl",
                    "description": "Path to the final sorted JSONL output file.",
                    "title": "output.file",
                    "type": "string"
                }
            },
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_pieces_netmon/tree/main/pieces/SortJSONLByFieldPiece"
    },
    "TimeWindowAggregationJSONLPiece": {
