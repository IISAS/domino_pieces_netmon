{
    "SortJSONLByFieldPiece": {
        "name": "SortJSONLByFieldPiece",
        "dependency": {
            "dockerfile": "Dockerfile",
            "requirements_file": null
        },
        "tags": [
            "processing",
            "stream",
            "jsonl"
        ],
        "style": {
            "node_label": "Sort by Field",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa7-solid:arrow-down-1-9",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Sort JSONL records by a specified field (e.g., timestamp).",
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "properties": {
                "input_file": {
                    "description": "Path to the input JSONL file containing messages to process.",
                    "title": "Input JSONL File",
                    "type": "string"
                },
                "output_file": {
                    "description": "Path to the output JSONL file.",
                    "title": "Output JSONL File",
                    "type": "string"
                },
                "field": {
                    "description": "Name of the field in each JSON message that contains JSON to extract.",
                    "title": "Field Name",
                    "type": "string"
                },
                "num_workers": {
                    "default": 4,
                    "description": "Number of workers to use.",
                    "title": "Number of Workers",
                    "type": "integer"
                }
            },
            "required": [
                "input_file",
                "output_file",
                "field"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "output_file": {
                    "default": "messages.jsonl",
                    "description": "Path to the final sorted JSONL output file.",
                    "title": "output.file",
                    "type": "string"
                }
            },
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_pieces_netmon/tree/main/pieces/SortJSONLByFieldPiece"
    },
    "TimeWindowAggregationJSONLPiece": {
        "name": "TimeWindowAggregationJSONLPiece",
        "dependency": {
            "dockerfile": "Dockerfile",
            "requirements_file": null
        },
        "tags": [
            "JSONL",
            "TimeWindow",
            "aggregation"
        ],
        "style": {
            "node_label": "Time Window Aggregation",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa7-solid:gears",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Rule-based batch processing of network monitor messages.",
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "$defs": {
                "AggregationRules": {
                    "properties": {
                        "agg": {
                            "additionalProperties": {
                                "items": {
                                    "enum": [
                                        "count",
                                        "nunique",
                                        "sum",
                                        "mean",
                                        "min",
                                        "max"
                                    ],
                                    "type": "string"
                                },
                                "type": "array"
                            },
                            "description": "Aggregation rules per protocol and field.",
                            "title": "Agg",
                            "type": "object"
                        },
                        "groupby": {
                            "anyOf": [
                                {
                                    "additionalProperties": {
                                        "items": {
                                            "enum": [
                                                "count",
                                                "nunique",
                                                "sum",
                                                "mean",
                                                "min",
                                                "max"
                                            ],
                                            "type": "string"
                                        },
                                        "type": "array"
                                    },
                                    "type": "object"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null,
                            "description": "Optional group-by aggregation rules per protocol.",
                            "title": "Groupby"
                        }
                    },
                    "required": [
                        "agg"
                    ],
                    "title": "AggregationRules",
                    "type": "object"
                },
                "DatasetCleaningRules": {
                    "properties": {
                        "to_numeric": {
                            "anyOf": [
                                {
                                    "$ref": "#/$defs/ToNumericRule"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null
                        },
                        "fillna": {
                            "anyOf": [
                                {
                                    "additionalProperties": {
                                        "items": {
                                            "type": "string"
                                        },
                                        "type": "array"
                                    },
                                    "type": "object"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null,
                            "title": "Fillna"
                        },
                        "astype": {
                            "anyOf": [
                                {
                                    "additionalProperties": {
                                        "items": {
                                            "type": "string"
                                        },
                                        "type": "array"
                                    },
                                    "propertyNames": {
                                        "enum": [
                                            "float",
                                            "int",
                                            "str"
                                        ]
                                    },
                                    "type": "object"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": null,
                            "title": "Astype"
                        }
                    },
                    "title": "DatasetCleaningRules",
                    "type": "object"
                },
                "NetDirection": {
                    "properties": {
                        "regex": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ],
                            "default": "",
                            "description": "Regex matching local networks. Leave empty if not used.",
                            "title": "Regex"
                        },
                        "field_name": {
                            "default": "mods_dir",
                            "description": "Name of the field storing computed network direction.",
                            "title": "Field Name",
                            "type": "string"
                        },
                        "orig_field": {
                            "default": "id.orig_h",
                            "description": "Field containing origin IP address.",
                            "title": "Orig Field",
                            "type": "string"
                        },
                        "resp_field": {
                            "default": "id.resp_h",
                            "description": "Field containing responder IP address.",
                            "title": "Resp Field",
                            "type": "string"
                        }
                    },
                    "title": "NetDirection",
                    "type": "object"
                },
                "ToNumericRule": {
                    "properties": {
                        "coerce": {
                            "description": "Columns to convert to numeric with coercion.",
                            "items": {
                                "type": "string"
                            },
                            "title": "Coerce",
                            "type": "array"
                        }
                    },
                    "required": [
                        "coerce"
                    ],
                    "title": "ToNumericRule",
                    "type": "object"
                }
            },
            "properties": {
                "input_file": {
                    "description": "Path to a file containing messages to process.",
                    "title": "input.file",
                    "type": "string"
                },
                "output_file": {
                    "description": "Path to a directory to write the processed messages.",
                    "title": "output.file",
                    "type": "string"
                },
                "field": {
                    "default": "ts_end",
                    "description": "Timestamp field to perform windowing over.",
                    "title": "field",
                    "type": "string"
                },
                "num_workers": {
                    "default": 4,
                    "description": "Number of parallel workers",
                    "title": "num.workers",
                    "type": "integer"
                },
                "data_cleaning_rules": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/DatasetCleaningRules"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": {},
                    "description": "Rules for cleaning dataset fields before aggregation.",
                    "title": "data.cleaning.rules"
                },
                "aggregation_period": {
                    "default": "PT10M",
                    "description": "Time window length for aggregation and minimum wait for delayed logs.",
                    "format": "duration",
                    "title": "aggregation.period",
                    "type": "string"
                },
                "aggregation_rules": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/AggregationRules"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": {
                        "agg": {
                            "proto": [
                                "count",
                                "nunique"
                            ],
                            "query": [
                                "count",
                                "nunique"
                            ],
                            "uid": [
                                "count",
                                "nunique"
                            ]
                        },
                        "groupby": {
                            "AA": [
                                "count"
                            ],
                            "RA": [
                                "count"
                            ],
                            "RD": [
                                "count"
                            ],
                            "TC": [
                                "count"
                            ],
                            "rejected": [
                                "count"
                            ]
                        }
                    },
                    "description": "JSON aggregation rules configuration.",
                    "title": "aggregation.rules"
                },
                "net_direction": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/NetDirection"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": {
                        "regex": "147\\.213\\..+",
                        "field": "mods_dir",
                        "orig_field": "id.orig_h",
                        "resp_field": "id.resp_h"
                    },
                    "description": "Configuration for computing network direction based on local network regex.",
                    "title": "net.direction"
                }
            },
            "required": [
                "input_file",
                "output_file"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "output_file": {
                    "description": "Ouput file path.",
                    "title": "output.file",
                    "type": "string"
                }
            },
            "required": [
                "output_file"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_pieces_netmon/tree/main/pieces/TimeWindowAggregationJSONLPiece"
    },
    "PartitionJSONLByFieldPiece": {
