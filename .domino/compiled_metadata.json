                    "description": "Mapping of partition names to their corresponding JSONL file paths.",
                    "title": "Partitions Mapping",
                    "type": "object"
                }
            },
            "required": [
                "partitions"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_pieces_netmon/tree/main/pieces/PartitionJSONLByFieldPiece"
    },
