{
    "TimeWindowAggregationPiece": {
        "name": "TimeWindowAggregationPiece",
        "dependency": {
            "dockerfile": "Dockerfile",
            "requirements_file": null
        },
        "tags": [
            "TimeWindow",
            "aggregation"
        ],
        "style": {
            "node_label": "Time Window Aggregation",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa7-solid:gears",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Rule-based batch processing of network monitor messages.",
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "properties": {
                "input_file": {
                    "description": "Path to a file containing messages to process.",
                    "from_upstream": "always",
                    "title": "input.file",
                    "type": "string"
                },
                "value_field": {
                    "default": "value",
                    "description": "Timestamp field to perform windowing over.",
                    "from_upstream": "never",
                    "title": "value.field",
                    "type": "string"
                },
                "field": {
                    "default": "ts_end",
                    "description": "Timestamp field to perform windowing over.",
                    "from_upstream": "never",
                    "title": "field",
                    "type": "string"
                },
                "num_workers": {
                    "default": 4,
                    "description": "Number of parallel workers",
                    "from_upstream": "never",
                    "title": "num.workers",
                    "type": "integer"
                },
                "data_cleaning_rules": {
                    "default": "{\"conn\": {\"to_numeric\": {\"coerce\": [\"duration\", \"orig_bytes\", \"resp_bytes\"]}, \"fillna\": [{\"value\": 0.0, \"type\": \"float\", \"fields\": [\"duration\"]}, {\"value\": 0, \"type\": \"int\", \"fields\": [\"orig_bytes\", \"resp_bytes\"]}], \"astype\": {\"float\": [\"duration\"], \"int\": [\"orig_bytes\", \"resp_bytes\"]}}}",
                    "description": "Rules for cleaning dataset fields before aggregation.",
                    "from_upstream": "never",
                    "title": "data.cleaning.rules",
                    "type": "string",
                    "widget": "codeeditor-json"
                },
                "aggregation_period": {
                    "default": "PT10M",
                    "description": "Time window length for aggregation and minimum wait for delayed logs.",
                    "format": "duration",
                    "from_upstream": "never",
                    "title": "aggregation.period",
                    "type": "string"
                },
                "aggregation_rules": {
                    "default": "{\"agg\": {\"conn\": {\"uid\": [\"count\", \"nunique\"], \"orig_bytes\": [\"sum\"], \"resp_bytes\": [\"sum\"], \"duration\": [\"mean\"]}, \"dns\": {\"uid\": [\"count\", \"nunique\"], \"query\": [\"count\", \"nunique\"], \"proto\": [\"count\", \"nunique\"]}, \"sip\": {\"uid\": [\"count\", \"nunique\"], \"id.orig_h\": [\"count\", \"nunique\"], \"id.orig_p\": [\"count\", \"nunique\"], \"id.resp_h\": [\"count\", \"nunique\"], \"id.resp_p\": [\"count\", \"nunique\"]}, \"ssh\": {\"uid\": [\"count\", \"nunique\"]}, \"ssl\": {\"uid\": [\"count\", \"nunique\"]}, \"http\": {\"uid\": [\"count\", \"nunique\"]}}, \"groupby\": {\"dns\": {\"AA\": [\"count\"], \"RA\": [\"count\"], \"RD\": [\"count\"], \"TC\": [\"count\"], \"rejected\": [\"count\"]}}}",
                    "description": "JSON aggregation rules configuration.",
                    "from_upstream": "never",
                    "title": "aggregation.rules",
                    "type": "string",
                    "widget": "codeeditor-json"
                },
                "net_direction": {
                    "default": "{\"regex\": \"147\\\\.213\\\\..+\", \"field\": \"mods_dir\", \"orig_field\": \"id.orig_h\", \"resp_field\": \"id.resp_h\"}",
                    "description": "Configuration for computing network direction based on local network regex.",
                    "from_upstream": "never",
                    "title": "net.direction",
                    "type": "string",
                    "widget": "codeeditor-json"
                }
            },
            "required": [
                "input_file"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "output_file": {
                    "description": "Ouput file path.",
                    "title": "output.file",
                    "type": "string"
                }
            },
            "required": [
                "output_file"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_pieces_netmon/tree/main/pieces/TimeWindowAggregationPiece"
    },
    "InferModelPiece": {
        "name": "InferModelPiece",
        "dependency": {
            "dockerfile": "Dockerfile.tensorflow-gpu",
            "requirements_file": null
        },
        "tags": [
            "JSONL",
            "inference",
            "model"
        ],
        "style": {
            "node_label": "Infer Model",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa7-solid:brain",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Runs inference on network monitoring data using a GRU model trained by TrainModelPiece.",
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "properties": {
                "model_file_path": {
                    "description": "Path to the trained Keras model file (from TrainModelPiece).",
                    "from_upstream": "always",
                    "title": "model.file.path",
                    "type": "string"
                },
                "input_file": {
                    "description": "Path to a JSONL file containing input data for inference.",
                    "from_upstream": "always",
                    "title": "input.file",
                    "type": "string"
                },
                "X": {
                    "default": [
                        "conn_count_uid_in",
                        "conn_count_uid_out",
                        "dns_count_uid_out",
                        "http_count_uid_in",
                        "ssl_count_uid_in"
                    ],
                    "description": "List of column names to use as input features. Must match the training configuration.",
                    "items": {
                        "type": "string"
                    },
                    "title": "Feature Columns (X)",
                    "type": "array"
                },
                "Y": {
                    "default": [
                        "conn_count_uid_in",
                        "conn_count_uid_out",
                        "dns_count_uid_out",
                        "http_count_uid_in",
                        "ssl_count_uid_in"
                    ],
                    "description": "List of column names used as targets. Must match the training configuration.",
                    "items": {
                        "type": "string"
                    },
                    "title": "Target Columns (Y)",
                    "type": "array"
                }
            },
            "required": [
                "model_file_path",
                "input_file"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "output_file": {
                    "default": "predictions.jsonl",
                    "description": "Path to the JSONL file containing model predictions.",
                    "title": "output.file",
                    "type": "string"
                }
            },
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_pieces_netmon/tree/main/pieces/InferModelPiece"
    },
    "TrainModelPiece": {
        "name": "TrainModelPiece",
        "dependency": {
            "dockerfile": "Dockerfile.tensorflow-gpu",
            "requirements_file": null
        },
        "tags": [
            "JSONL",
            "TimeWindow",
            "aggregation"
        ],
        "style": {
            "node_label": "Train Model",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa7-solid:brain",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Trains a GRU-based time series model on network monitoring data.",
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "properties": {
                "input_file": {
                    "description": "Path to a file containing training data.",
                    "title": "input.file",
                    "type": "string"
                },
                "split": {
                    "default": 0.7,
                    "description": "The proportion of training data to be used for training the model.",
                    "title": "split.ratio",
                    "type": "number"
                },
                "diff": {
                    "default": false,
                    "description": "Apply first-order differencing to the input sequence before training. Each value is replaced by its difference from the previous timestep: [x\u2081, x\u2082, ..., x\u2099] \u2192 [x\u2082\u2212x\u2081, x\u2083\u2212x\u2082, ..., x\u2099\u2212x\u2099\u208b\u2081].",
                    "title": "differencing",
                    "type": "boolean"
                },
                "seq_len_in": {
                    "default": 24,
                    "description": "Length of the model's input sequence (in number of timesteps).",
                    "title": "seq.len.in",
                    "type": "integer"
                },
                "seq_len_out": {
                    "default": 1,
                    "description": "Length of the model's output sequence (in number of timesteps).",
                    "title": "seq.len.out",
                    "type": "integer"
                },
                "teacher_forcing": {
                    "default": false,
                    "description": "Whether or not to use teacher forcing.",
                    "title": "teacher.forcing",
                    "type": "boolean"
                },
                "gru_units": {
                    "default": 60,
                    "description": "The number of GRU units in the model.",
                    "title": "GRU units",
                    "type": "integer"
                },
                "dropout_rate": {
                    "default": 0.6,
                    "description": "The dropout rate for the model.",
                    "title": "dropout.rate",
                    "type": "number"
                },
                "batch_size": {
                    "default": 1,
                    "description": "The batch size for training the model.",
                    "title": "batch.size",
                    "type": "integer"
                },
                "epochs": {
                    "default": 100,
                    "description": "The number of training epochs.",
                    "title": "epochs",
                    "type": "integer"
                },
                "epochs_patience": {
                    "default": 10,
                    "description": "The number of epochs to wait before stopping training.",
                    "title": "epochs_patience",
                    "type": "integer"
                },
                "X": {
                    "default": [
                        "conn_count_uid_in",
                        "conn_count_uid_out",
                        "dns_count_uid_out",
                        "http_count_uid_in",
                        "ssl_count_uid_in"
                    ],
                    "description": "List of column names to be used as input features for the model training (independent variables).",
                    "items": {
                        "type": "string"
                    },
                    "title": "Feature Columns (X)",
                    "type": "array"
                },
                "Y": {
                    "default": [
                        "conn_count_uid_in",
                        "conn_count_uid_out",
                        "dns_count_uid_out",
                        "http_count_uid_in",
                        "ssl_count_uid_in"
                    ],
                    "description": "List of column names to be used as target variables for the model training (dependent variables).",
                    "items": {
                        "type": "string"
                    },
                    "title": "Target Columns (Y)",
                    "type": "array"
                }
            },
            "required": [
                "input_file"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "best_model_file_path": {
                    "default": "best_model.keras",
                    "description": "Path to the saved best model.",
                    "title": "best_model_file_path",
                    "type": "string"
                },
                "last_model_file_path": {
                    "default": "last_model.keras",
                    "description": "Path to the saved last model.",
                    "title": "last_model_file_path",
                    "type": "string"
                }
            },
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/IISAS/domino_pieces_netmon/tree/main/pieces/TrainModelPiece"
    }
}